# ============================================================
# Runtime
# ============================================================
NODE_ENV=development
PORT=3000

# ============================================================
# Base de datos (Postgres)
# ============================================================
DATABASE_URL="postgresql://user:pass@localhost:5432/pasarela?schema=public"

# ============================================================
# Redis (colas + idempotencia + rate limiting)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# Rate limiting por tenant (req por minuto)
# ============================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=200
THROTTLE_LIMIT_PER_TENANT=200

# ============================================================
# Webhook secrets — rotation: define el anterior durante la ventana
# ============================================================
WEBHOOK_SIGNING_SECRET=change-me-in-production
WEBHOOK_SIGNING_SECRET_PREVIOUS=
WEBHOOK_TOLERANCE_SECONDS=300

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info

# ============================================================
# OpenTelemetry (opcional, default desactivado)
# ============================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pasarela-pagos
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ============================================================
# Reconciliación (cron expression, default: cada 5 minutos)
# ============================================================
# RECONCILE_CRON=*/5 * * * *

# ============================================================
# Firebase — mismo proyecto que el owner-dashboard
# Obtener desde: Firebase Console → Configuración → Cuentas de servicio
# ============================================================
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# Nota: los \n en la private key deben ser literales \\n en el .env
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ============================================================
# Ecosistema SSO — URL del owner-dashboard
# Usado para consultar memberships/permisos si los claims del token están vacíos
# ============================================================
DASHBOARD_API_URL=http://localhost:3001

# ============================================================
# Providers de pago (solo los que uses)
# ============================================================

# Stripe (US, EU, internacional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MercadoPago (AR, BR, MX, CO, CL, PE, UY)
MERCADOPAGO_ACCESS_TOKEN=TEST-...
MERCADOPAGO_WEBHOOK_SECRET=

# Pagar.me (BR: card + PIX)
PAGARME_API_KEY=ak_test_...
PAGARME_WEBHOOK_SECRET=

# Conekta (MX: card + OXXO)
CONEKTA_PRIVATE_KEY=key_test_...
CONEKTA_WEBHOOK_SECRET=

# dLocal (PE, CL, CO, UY y más)
DLOCAL_API_KEY=
DLOCAL_SECRET_KEY=

# ============================================================
# PII encryption (opcional, requerido en producción)
# ============================================================
# PII_ENCRYPTION_KEY=<64 char hex>
# PII_SEARCH_SALT=<random string>
